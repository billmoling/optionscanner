# Copy this file to `.env` and fill in actual values for local development.
# Environment variables defined here are loaded by Docker Compose and the application.

#
# IBKR Gateway Credentials
#
TWS_USERID=
TWS_PASSWORD=
IAPI_CLIENT_ID=1
TRADING_MODE=paper
VNC_SERVER_PASSWORD=
READ_ONLY_API=no

#
# IBKR Connection Settings
#
# For local development (host machine connecting to localhost):
#   IBKR_HOST=127.0.0.1
#   IBKR_PORT=4002
#
# For Docker Compose (app container connecting to ib-gateway container):
#   IBKR_HOST=ib-gateway
#   IBKR_PORT=4004 (paper) or 4003 (live)
#
IBKR_HOST=ib-gateway
IBKR_PORT=4004
IBKR_CLIENT_ID=1

#
# Notifications
#
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_TEST_CHANNEL=#option-scanner-test

#
# AI Services
#
GEMINI_API_KEY=

#
# Market Data
# Use FROZEN for paper trading (no market data subscription needed)
# Use LIVE for live trading or if you have real-time data subscriptions
#
IBKR_MARKET_DATA_TYPE=FROZEN
DISABLE_PORTFOLIO_MANAGER=no

#
# Grafana Loki (optional - centralized logging)
#
LOKI_URL=https://logs-prod-018.grafana.net
LOKI_USERNAME=1413391
LOKI_PASSWORD=

# Reddit RSS feed monitoring for Whale Following strategy
# No API credentials required - uses public RSS feeds
# Configure subreddits in config.yaml under the 'reddit' section

# Financial Modeling Prep API key for earnings calendar data
# Required for earnings monitoring and pre-earnings strategy
# Free tier: 250 requests/day, 30 calls/minute
# Get your API key at: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=


